@sbahn-color: #0c0;
@fbahn-color: #000;
@subway-color: #00f;
@tram-color: #d0f;
@aerialway-color: #642;
@trolleybus-color: #b22;
@bus-color: #f00;
@ferry-color: #ff7fbf;


/* The order of styles plays an important role in what covers what. It seems that due to the way that CartoCSS resolves
   nested rules, the first time a layer/attachment is referenced will determine its final position in the compiled style,
   regardless of whether that same layer/attachment is mentioned somewhere else later. Layers define the order at a
   higher level, meaning that the first time a layer is used determines its position, and the first time an attachment
   is used determines its position within its layer.

   The order of layers/attachments has two separate contradicting impacts:
   1. Later layers are rendered on top of earlier layers, meaning their features will cover the features of earlier layers.
   2. For features with collision prevention enabled (markers and text have it enabled by default, but lines don't),
      whatever feature is rendered first occupies the space.
   This means that for features without collision prevention, later layers have "priority" (they will be more visible on
   the resulting map), while for features with collision prevention, earlier layers have priority.

   The following layers are ordered in a way that tries to achieve the desired result by keeping these complexities in
   mind. In some cases, this means duplicating a data query to split up the results in two layers (station icons
   should be rendered on top of route lines, but should have higher priority than route numbers for collision prevention,
   meaning they must be rendered in between route lines and labels, so routes have to be split up into two layers that
   both reference the same data.

   Within the layers, we try to order the different modes of transportation using attachments by this order of priority
   (from highest to lowest):
   1. sbahn (rendered above fbahn with slightly narrower lines because they often use the same tracks)
   2. fbahn
   3. subway
   4. tram, monorail, funicular, aerialway, trolleybus
   5. bus, ferry
*/


/* ================================================================== */
/* ROUTE LINES                                                        */
/* ================================================================== */

#pt_lines {
    line-join: round;
    line-cap: round;
    line-width: 0;

    /* Each mode is rendered as a separate attachment so they cover each other in the indended way.
       Because lines do not have collision prevention, items further down are rendered with higher priority. */

    ::bus {
        [mode='ferry'] {
            line-color: @ferry-color;
            [zoom >= 12] { line-width: 3; }
            [zoom >= 15] { line-width: 6; }
        }

        [mode='bus'] {
            line-color: @bus-color;
            [zoom >= 12] { line-width: 3; }
            [zoom >= 15] { line-width: 6; }

            [state='alternate'] {
                [zoom >= 12] { line-dasharray: 6, 6; }
                [zoom >= 15] { line-dasharray: 12, 12; }
            }
        }
    }

    ::tram {
        [mode='trolleybus'] {
            line-color: @trolleybus-color;
            [zoom >= 11] { line-width: 3; }
            [zoom >= 15] { line-width: 6; }
        }

        [mode='aerialway'] {
            line-color: @aerialway-color;
            [zoom >= 11] { line-width: 3; }
            [zoom >= 15] { line-width: 6; }
        }

        [mode='funicular'], [mode='monorail'], [mode='tram'] {
            line-color: @tram-color;
            [zoom = 11] { line-width: 3; }
            [zoom >= 12] { line-width: 6; }
        }
    }

    ::subway[mode='subway'] {
        line-color: @subway-color;
        [zoom = 11] { line-width: 3; }
        [zoom >= 12] { line-width: 6; }

        /* Render gaps in the line for direction arrows (black arrows would be hard to see on a blue line) */
        [zoom >= 17] {
            direction/line-color: #ffffff;
            direction/line-width: 6;
            direction/line-join: bevel;
            direction/line-dasharray: 0, 8, 11, 71;
        }
    }

    ::fbahn[mode='fbahn'] {
        line-color: @fbahn-color;
        [zoom = 5] { line-width: 1; }
        [zoom = 6] { line-width: 2; }
        [zoom >= 7][zoom <= 8] { line-width: 5; }
        [zoom >= 9] { line-width: 8; }
    }

    ::sbahn[mode='sbahn'] {
        [zoom = 6] { line-color: @fbahn-color; line-width: 1; }
        [zoom >= 7][zoom <= 8] { line-color: @sbahn-color; line-width: 3; }
        [zoom >= 9] { line-color: @sbahn-color; line-width: 6; }
    }

    ::subway[mode='subway'], ::tram[mode='tram'], ::tram[mode='monorail'] {
        /* Render direction arrows */
        ::direction[zoom >= 17] {
            line1/line-color: #000000;
            line1/line-width: 1;
            line1/line-join: bevel;
            line1/line-dasharray: 0, 10, 8, 72;

            line2/line-color: #000000;
            line2/line-width: 2;
            line2/line-join: bevel;
            line2/line-dasharray: 0, 10, 7, 73;

            line3/line-color: #000000;
            line3/line-width: 3;
            line3/line-join: bevel;
            line3/line-dasharray: 0, 10, 6, 74;

            line4/line-color: #000000;
            line4/line-width: 4;
            line4/line-join: bevel;
            line4/line-dasharray: 0, 10, 5, 75;

            line5/line-color: #000000;
            line5/line-width: 5;
            line5/line-join: bevel;
            line5/line-dasharray: 0, 10, 4, 76;

            line6/line-color: #000000;
            line6/line-width: 6;
            line6/line-join: bevel;
            line6/line-dasharray: 0, 10, 3, 77;

            line7/line-color: #000000;
            line7/line-width: 7;
            line7/line-join: bevel;
            line7/line-dasharray: 0, 10, 2, 78;

            line8/line-color: #000000;
            line8/line-width: 8;
            line8/line-join: bevel;
            line8/line-dasharray: 0, 10, 1, 79;
        }
    }
}


/* ================================================================== */
/* STATION ICONS                                                      */
/* ================================================================== */

#pt_stations_point, #pt_stations_poly {

    /* Here, collision prevention is active, so markers will not cover each other and items further up have higher
       priority. */

    ::mainstation[type='mainstation'], ::station[type='station'] {
        [zoom >= 12] {
            marker-file: url('./symbols/station_small.png');
        }
        [zoom >= 15] {
            marker-file: url('./symbols/station.png');
        }
    }

    ::halt[type='halt'], ::halt[type='tram_stop'], ::halt[type='aerialway_station'] {
        [zoom >= 12] {
            marker-file: url('./symbols/halt.png');
        }
        [zoom >= 15] {
            marker-file: url('./symbols/station_small.png');
        }
    }

    ::bus_station[type='bus_station'] {
        [zoom >= 13] {
            marker-file: url('./symbols/halt.png');
        }
        [zoom >= 15] {
            marker-file: url('./symbols/station_small.png');
        }
    }

    ::bus_stop[type='bus_stop'] {
        [zoom >= 13] {
            marker-file: url('./symbols/bus_stop_small.png');
        }
        [zoom >= 15] {
            marker-file: url('./symbols/halt.png');
        }
    }
}


/* ================================================================== */
/* STATION LABELS                                                     */
/* ================================================================== */

#pt_stations_point, #pt_stations_poly {

    ::mainstation-label[type='mainstation'] {
        [zoom >= 7][zoom <= 11] {
            text-name: "[shortname]";
            text-face-name: @bold-fonts;
            text-size: 12;
            text-fill: black;
            text-halo-radius: 2;
        }
    }

    ::mainstation-label[type='mainstation'], ::station-label[type='station'] {
        [zoom >= 12] {
            text-name: "[name]";
            text-face-name: @bold-fonts;
            text-size: 10;
            text-fill: #000;
            text-dy: -8;
            text-halo-radius: 1;
        }
        [zoom >= 15] {
            text-size: 12;
            text-dy: -10;
        }
    }

    ::halt-label[type='halt'], ::halt-label[type='tram_stop'], ::halt-label[type='aerialway_station'] {
        [zoom >= 13] {
            text-name: "[name]";
            text-face-name: @book-fonts;
            text-size: 9;
            text-fill: #000;
            text-dy: -7;
            text-halo-radius: 1;
        }
        [zoom >= 15] {
            text-size: 11;
            text-dy: -8;
        }
    }

    ::bus_station-label[type='bus_station'] {
        [zoom >= 13] {
            text-name: "[name]";
            text-face-name: @book-fonts;
            text-size: 9;
            text-fill: #000;
            text-dy: -7;
            text-halo-radius: 1;
        }
        [zoom >= 15] {
            text-size: 11;
            text-dy: -8;
        }
    }

    ::bus_stop-label[type='bus_stop'] {
        [zoom >= 15] {
            text-name: "[name]";
            text-face-name: @book-fonts;
            text-size: 9;
            text-fill: #000;
            text-dy: -7;
            text-halo-radius: 1;
            text-placement: point;
            text-allow-overlap: true;
        }
    }
}


/* ================================================================== */
/* ROUTE LABELS                                                       */
/* ================================================================== */

#pt_lines_labels {
    line-width: 0;

    [ref != null] {
        ::sbahn-labels[mode='sbahn'][zoom >= 7],
        ::fbahn-labels[mode='fbahn'][zoom >= 7],
        ::tram-labels[mode='subway'][zoom >= 11],
        ::tram-labels[mode='tram'][zoom >= 11],
        ::tram-labels[mode='monorail'][zoom >= 11],
        ::tram-labels[mode='funicular'][zoom >= 11],
        ::tram-labels[mode='trolleybus'][zoom >= 11],
        ::tram-labels[mode='aerialway'][zoom >= 11],
        ::bus-labels[mode='bus'][zoom >= 12],
        ::bus-labels[mode='ferry'][zoom >= 12] {
            text: none;
            text-name: "' ' + [ref] + ' '";
            text-face-name: @bold-fonts;
            text-halo-radius: 1;
            text-placement: line;
            text-repeat-distance: 30;
            text-spacing: 200;
            text-wrap-width: 12;
            text-wrap-character: ";";
            text-avoid-edges: true;

            [mode='ferry'] {
                text-fill: @ferry-color;

                [zoom >= 12] { text-size: 8; }
                [zoom >= 15] { text-size: 11; }
            }

            [mode='bus'] {
                text-fill: @bus-color;
                text-name: "'  ' + [ref] + '  '";

                [zoom >= 12] { text-size: 8; }
                [zoom >= 15] { text-size: 11; }

                [state='alternate'] { text-name: "'  (' + [ref] + ')  '"; }
            }

            [mode='tram'], [mode='monorail'], [mode='funicular'] {
                text-fill: @tram-color;

                [zoom >= 11] { text-size: 8; }
                [zoom >= 12] { text-size: 11; }
            }

            [mode='trolleybus'] {
                text-fill: @trolleybus-color;

                [zoom >= 11] { text-size: 8; }
                [zoom >= 15] { text-size: 11; }
            }

            [mode='aerialway'] {
                text-fill: @aerialway-color;

                [zoom >= 11] { text-size: 8; }
                [zoom >= 15] { text-size: 11; }
            }

            [mode='subway'] {
                text-fill: @subway-color;

                [zoom >= 11] { text-size: 8; }
                [zoom >= 12] { text-size: 11; }
            }

            [mode='fbahn'] {
                text-fill: @fbahn-color;

                [zoom >= 7] { text-size: 9; }
                [zoom >= 9] { text-size: 12; }
            }

            [mode='sbahn'] {
                text-fill: @sbahn-color;

                [zoom >= 7] { text-size: 8; }
                [zoom >= 9] { text-size: 11; }
            }
        }
    }
}